@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;600;700;800;900&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  * {
    box-sizing: border-box;
  }

  /* light mode by default */
  body {
    @apply bg-white text-dark-900 font-sans antialiased;
  }

  /* dark mode overrides */
  .dark body {
    @apply bg-dark-900 text-white;
  }

  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #0d1117;
  }
  ::-webkit-scrollbar-thumb {
    background: #1e2a40;
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #22c55e;
  }
}

@layer components {
  .btn-primary {
    @apply bg-indigo-600 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-indigo-500 transition-all duration-200 active:scale-95;
  }

  .btn-secondary {
    @apply border border-[#1e2535] text-gray-300 font-semibold px-5 py-2.5 rounded-lg hover:border-brand-green hover:text-brand-green transition-all duration-200 active:scale-95;
  }

  .card {
    @apply bg-[#141b26] border border-[#1e2535] rounded-xl p-5 transition-all duration-200;
  }

  .card-hover {
    @apply card hover:border-brand-green/40 hover:shadow-green cursor-pointer;
  }

  .badge {
    @apply text-xs font-semibold px-2.5 py-1 rounded-full;
  }

  .badge-green {
    @apply badge bg-brand-green/20 text-brand-green border border-brand-green/30;
  }

  .nav-link {
    @apply flex items-center gap-3 px-4 py-2.5 rounded-lg text-gray-400 hover:text-white hover:bg-[#1a2235] transition-all duration-200 font-medium text-sm;
  }

  .nav-link-active {
    @apply nav-link text-brand-green bg-brand-green/10 border border-brand-green/20;
  }

  .stat-up {
    @apply text-brand-green text-xs font-semibold;
  }

  .stat-down {
    @apply text-red-400 text-xs font-semibold;
  }

  .input-field {
    @apply w-full bg-[#0d1117] border border-[#1e2535] text-white placeholder-gray-600 rounded-lg px-4 py-3 focus:outline-none focus:border-brand-green focus:ring-1 focus:ring-brand-green/30 transition-all duration-200 text-sm;
  }

  .select-field {
    @apply input-field appearance-none cursor-pointer;
  }

  .section-title {
    @apply text-xl font-bold text-white;
  }

  .section-sub {
    @apply text-sm text-gray-400;
  }
}

@layer utilities {
  .text-gradient {
    @apply bg-gradient-to-r from-brand-green to-brand-green-light bg-clip-text text-transparent;
  }

  .bg-glow-green {
    background: radial-gradient(ellipse at center, rgba(34,197,94,0.15) 0%, transparent 70%);
  }

  .ring-green {
    @apply ring-1 ring-brand-green/30;
  }

  .glow-dot {
    @apply w-2 h-2 rounded-full bg-brand-green animate-pulse-slow;
  }
}
